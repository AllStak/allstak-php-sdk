{
    "name": "allstak/fixture-laravel-10",
    "description": "Fixture testing allstak/sdk-php against Laravel ^10.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../../..",
            "options": { "symlink": false }
        }
    ],
    "require": {
        "php": ">=8.1",
        "allstak/sdk-php": "*@dev",
        "laravel/framework": "^10.0"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
