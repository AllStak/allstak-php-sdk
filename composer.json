{
    "name": "allstak/sdk-php",
    "description": "Official AllStak PHP SDK — drop-in observability for plain PHP and Laravel apps. Captures errors, logs, HTTP requests, DB queries, traces, outbound HTTP, and scheduled cron tasks with one Composer require and one API key.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "keywords": [
        "allstak",
        "observability",
        "monitoring",
        "error-tracking",
        "logging",
        "tracing",
        "apm",
        "laravel",
        "php"
    ],
    "homepage": "https://allstak.sa",
    "support": {
        "issues": "https://github.com/AllStak/allstak-php-sdk/issues",
        "source": "https://github.com/AllStak/allstak-php-sdk",
        "docs": "https://docs.allstak.sa/sdk/php"
    },
    "authors": [
        {
            "name": "AllStak",
            "homepage": "https://allstak.sa"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/promises": "^2.0",
        "psr/http-message": "^1.0|^2.0"
    },
    "suggest": {
        "illuminate/support": "Required for the optional Laravel integration (auto-discovered service provider).",
        "guzzlehttp/guzzle": "Required for outbound HTTP capture via Laravel's Http client (already installed by laravel/framework)."
    },
    "autoload": {
        "psr-4": {
            "AllStak\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AllStak\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AllStak\\Laravel\\AllStakServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "sort-packages": true
    }
}
