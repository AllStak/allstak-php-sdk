{
    "name": "allstak/sdk-php",
    "description": "AllStak PHP SDK — error tracking, logs, HTTP monitoring, cron heartbeat, feature flags",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "AllStak\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AllStak\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
